# PostgreSQL пароль (придумай сложный)
DB_PASSWORD=change_me_strong_password

# OpenAI ключ (sk-...)
OPENAI_API_KEY=sk-...

# JWT секрет — сгенерируй:
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_64_char_random_string

# Не используется, оставь пустым
ANTHROPIC_API_KEY=